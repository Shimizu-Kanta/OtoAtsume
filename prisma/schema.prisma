generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String    @id @default(uuid())
  email     String    @unique
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())

  @@map("admin_users")
}

model Group {
  id         String      @id @default(uuid())
  name       String      @unique
  performers Performer[]
  performerApplications PerformerApplication[]
  createdAt  DateTime    @default(now())

  @@map("groups")
}

model Performer {
  id          String           @id @default(uuid())
  name        String
  groupId     String?
  group       Group?           @relation(fields: [groupId], references: [id])
  youtubeUrl  String?
  officialUrl String?
  colorCode   String?
  debutDate   DateTime?        @db.Date
  birthday    DateTime?        @db.Date
  status      MasterDataStatus @default(APPROVED)
  aliases     PerformerAlias[]
  tags        PerformerTag[]
  covers      CoverPerformer[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([name])
  @@index([groupId])
  @@index([debutDate])
  @@index([birthday])
  @@map("performers")
}

model PerformerAlias {
  id          String    @id @default(uuid())
  performerId String
  performer   Performer @relation(fields: [performerId], references: [id], onDelete: Cascade)
  alias       String

  @@unique([performerId, alias])
  @@index([alias])
  @@map("performer_aliases")
}

model Tag {
  id         String         @id @default(uuid())
  name       String         @unique
  performers PerformerTag[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([name])
  @@map("tags")
}

model PerformerTag {
  performerId String
  tagId       String

  performer Performer @relation(fields: [performerId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([performerId, tagId])
  @@index([tagId])
  @@map("performer_tags")
}

model Artist {
  id        String       @id @default(uuid())
  name      String       @unique
  songs     SongArtist[]
  createdAt DateTime     @default(now())

  @@index([name])
  @@map("artists")
}

model Song {
  id          String       @id @default(uuid())
  title       String
  originalUrl String?
  artists     SongArtist[]
  covers      Cover[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([title])
  @@map("songs")
}

model SongArtist {
  id       String @id @default(uuid())
  songId   String
  artistId String

  song   Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([songId, artistId])
  @@index([artistId])
  @@map("song_artists")
}

model Cover {
  id               String           @id @default(uuid())
  songId           String
  song             Song             @relation(fields: [songId], references: [id])
  performedAt      DateTime
  coverType        CoverType
  sourceUrl        String
  sourceTitle      String?
  timestampSeconds Int?
  status           ContentStatus    @default(APPROVED)
  ipHash           String?
  userAgentHash    String?
  performers       CoverPerformer[]
  reports          Report[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([songId])
  @@index([performedAt])
  @@index([sourceUrl])
  @@index([coverType])
  @@index([status])
  @@map("covers")
}

model CoverPerformer {
  id          String @id @default(uuid())
  coverId     String
  performerId String

  cover     Cover     @relation(fields: [coverId], references: [id], onDelete: Cascade)
  performer Performer @relation(fields: [performerId], references: [id], onDelete: Cascade)

  @@unique([coverId, performerId])
  @@index([performerId])
  @@map("cover_performers")
}

model Report {
  id        String       @id @default(uuid())
  coverId   String
  cover     Cover        @relation(fields: [coverId], references: [id], onDelete: Cascade)
  reason    ReportReason
  memo      String?
  status    ReportStatus @default(PENDING)
  ipHash    String?
  createdAt DateTime     @default(now())

  @@index([coverId])
  @@index([status])
  @@map("reports")
}

model PerformerApplication {
  id        String            @id @default(uuid())
  name      String
  url       String
  groupId   String?
  group     Group?            @relation(fields: [groupId], references: [id])
  memo      String?
  status    ApplicationStatus @default(PENDING)
  ipHash    String?
  createdAt DateTime          @default(now())

  @@index([name])
  @@index([groupId])
  @@index([status])
  @@map("performer_applications")
}

model RateLimitBucket {
  id        String   @id @default(uuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
  @@map("rate_limit_buckets")
}

model YouTubeVideoMetadataCache {
  id           String   @id @default(uuid())
  videoId      String   @unique
  canonicalUrl String
  sourceTitle  String
  description  String
  publishedAt  DateTime
  channelId    String
  channelTitle String
  thumbnailUrl String?
  tags         String[] @default([])
  fetchedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([channelId])
  @@index([fetchedAt])
  @@map("youtube_video_metadata_cache")
}

model SiteAccessLog {
  id        String   @id @default(uuid())
  path      String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@map("site_access_logs")
}

model AppErrorLog {
  id        String   @id @default(uuid())
  type      String
  message   String?
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@map("app_error_logs")
}

model DailySiteReport {
  id                    String   @id @default(uuid())
  date                  DateTime @unique @db.Date
  accessCount           Int
  addedCoverCount       Int
  addedSongCount        Int
  pendingReportCount    Int
  pendingPerformerCount Int
  errorCounts           Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([date])
  @@map("daily_site_reports")
}

enum AdminRole {
  ADMIN
}

enum MasterDataStatus {
  PENDING
  APPROVED
  HIDDEN
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum CoverType {
  COVER_VIDEO
  KARAOKE_STREAM
  LIVE_EVENT
  SHORT
  OTHER
}

enum ReportReason {
  WRONG_SONG
  WRONG_PERFORMER
  WRONG_DATE
  BROKEN_URL
  MEMBERS_ONLY_CONTENT
  NON_PUBLIC_PAID_CONTENT
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
